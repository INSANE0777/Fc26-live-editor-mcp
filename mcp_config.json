{
  "_comment": "Replace placeholder paths with your actual FC 26 and Live Editor paths",
  "mcpServers": {
    "fc26-squad-file": {
      "command": "fc26-mcp-file",
      "args": [
        "--squad-file",
        "C:\Path\To\Your\SquadsFile"
      ],
      "env": {
        "FIFA_SQUAD_FILE": "C:\Path\To\Your\SquadsFile"
      },
      "lifecycle": "lazy"
    },
    "fc26-live-editor": {
      "command": "fc26-mcp-live",
      "args": [
        "--bridge-root",
        "C:\Path\To\Your\FC 26 LE\le_bridge"
      ],
      "env": {
        "FC26_BRIDGE_ROOT": "C:\Path\To\Your\FC 26 LE\le_bridge"
      },
      "lifecycle": "lazy"
    }
  }
}
